generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  PREFER_NOT_TO_SAY
}

enum PaymentStatus {
  EXTERNAL_PENDING
  CONFIRMED
  WAIVED
}

enum PhotoStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PhotoPurpose {
  GALLERY
  REMEMBRANCE
}

enum PairingStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum RsvpSource {
  FORM
  REGISTRATION
}

enum RegistrationCheckoutStatus {
  PENDING
  CONFIRMED
  PAYMENT_REVIEW
}

enum RsvpCheckoutStatus {
  PENDING
  CONFIRMED
  PAYMENT_REVIEW
}

model Participant {
  id            String          @id @default(cuid())
  firstName     String
  lastName      String
  email         String?         @unique
  phone         String?
  gender        Gender
  age           Int
  averageScore  Int
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  registrations Registration[]
  rsvps         Rsvp[]
  pairingSlots  PairingMember[]

  @@index([gender, averageScore, age])
}

model Registration {
  id               String                @id @default(cuid())
  participantId    String                @unique
  checkoutId       String?
  packageSelection String
  adultGuestCount  Int                   @default(0)
  childGuestCount  Int                   @default(0)
  dayBeforeRsvp    Boolean               @default(false)
  paymentStatus    PaymentStatus         @default(EXTERNAL_PENDING)
  paymentReference String?
  notes            String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  participant      Participant           @relation(fields: [participantId], references: [id], onDelete: Cascade)
  primaryCheckout  RegistrationCheckout? @relation("PrimaryRegistration")
  checkout         RegistrationCheckout? @relation("RegistrationCheckoutBatch", fields: [checkoutId], references: [id], onDelete: SetNull)

  @@index([paymentStatus])
  @@index([paymentReference])
  @@index([checkoutId])
  @@index([createdAt])
}

model RegistrationCheckout {
  id                  String                     @id @default(cuid())
  idempotencyKey      String                     @unique
  email               String
  payload             Json
  paymentReference    String?                    @unique
  paymentOrderId      String?                    @unique
  paymentUrl          String?
  status              RegistrationCheckoutStatus @default(PENDING)
  registrationId      String?                    @unique
  confirmedAt         DateTime?
  paymentCompletedAt  DateTime?
  paymentReviewReason String?
  lastReconciledAt    DateTime?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  registration        Registration?              @relation("PrimaryRegistration", fields: [registrationId], references: [id], onDelete: SetNull)
  registrations       Registration[]             @relation("RegistrationCheckoutBatch")

  @@index([email])
  @@index([status, createdAt])
}

model Rsvp {
  id                 String        @id @default(cuid())
  participantId      String?
  source             RsvpSource    @default(FORM)
  firstName          String
  lastName           String
  email              String        @unique
  attending          Boolean
  adultAttendeeCount Int?
  childAttendeeCount Int?
  attendeeCount      Int           @default(1)
  familyNames        String?
  dietaryNotes       String?
  notes              String?
  createdAt          DateTime      @default(now())
  participant        Participant?  @relation(fields: [participantId], references: [id], onDelete: SetNull)
  checkout           RsvpCheckout?

  @@unique([participantId, source], name: "participantId_source")
  @@index([attending])
  @@index([createdAt])
}

model RsvpCheckout {
  id                  String             @id @default(cuid())
  idempotencyKey      String             @unique
  email               String
  payload             Json
  paymentReference    String?            @unique
  paymentOrderId      String?            @unique
  paymentUrl          String?
  status              RsvpCheckoutStatus @default(PENDING)
  rsvpId              String?            @unique
  confirmedAt         DateTime?
  paymentCompletedAt  DateTime?
  paymentReviewReason String?
  lastReconciledAt    DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  rsvp                Rsvp?              @relation(fields: [rsvpId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([status, createdAt])
}

model Feedback {
  id                String            @id @default(cuid())
  name              String?
  email             String?
  rating            Int?
  category          String
  message           String
  createdAt         DateTime          @default(now())
  remembrancePhotos PhotoSubmission[]

  @@index([category])
  @@index([createdAt])
}

model PhotoSubmission {
  id             String       @id @default(cuid())
  submitterName  String
  submitterEmail String
  caption        String?
  purpose        PhotoPurpose @default(GALLERY)
  feedbackId     String?
  s3Key          String       @unique
  approvedS3Key  String?
  status         PhotoStatus  @default(PENDING)
  reviewNotes    String?
  approvedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  feedback       Feedback?    @relation(fields: [feedbackId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([feedbackId])
}

model PairingGroup {
  id          String          @id @default(cuid())
  name        String
  teeTime     DateTime?
  sortOrder   Int
  status      PairingStatus   @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  members     PairingMember[]

  @@index([status, sortOrder])
}

model PairingMember {
  id             String       @id @default(cuid())
  groupId        String
  participantId  String
  slot           Int
  snapshotScore  Int
  snapshotAge    Int
  snapshotGender Gender
  group          PairingGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  participant    Participant  @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([groupId, slot])
  @@index([participantId])
}

model EventSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}
