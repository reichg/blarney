generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  MALE
  FEMALE
}

enum PaymentStatus {
  EXTERNAL_PENDING
  CONFIRMED
  WAIVED
}

enum PhotoStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PhotoPurpose {
  GALLERY
  REMEMBRANCE
}

enum PairingStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum RsvpSource {
  FORM
  REGISTRATION
}

enum RegistrationCheckoutStatus {
  PENDING
  CONFIRMED
  PAYMENT_REVIEW
}

enum RsvpCheckoutStatus {
  PENDING
  CONFIRMED
  PAYMENT_REVIEW
}

enum MarketplaceListingStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum MarketplaceCheckoutStatus {
  PENDING
  PAYMENT_REVIEW
  CONFIRMED
  EXPIRED
  CANCELED
}

enum MarketplacePaymentProvider {
  SQUARE
}

enum MarketplacePaymentAttemptStatus {
  PENDING
  OPEN
  REVIEW
  COMPLETED
  EXPIRED
  CANCELED
}

enum MarketplaceFulfillmentStatus {
  UNFULFILLED
  READY
  FULFILLED
  CANCELED
}

model Participant {
  id            String          @id @default(cuid())
  firstName     String
  lastName      String
  email         String?         @unique
  phone         String?
  gender        Gender
  age           Int
  averageScore  Int
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  registrations Registration[]
  rsvps         Rsvp[]
  pairingSlots  PairingMember[]

  @@index([gender, averageScore, age])
}

model Registration {
  id               String                @id @default(cuid())
  participantId    String                @unique
  checkoutId       String?
  packageSelection String
  adultGuestCount  Int                   @default(0)
  childGuestCount  Int                   @default(0)
  paymentStatus    PaymentStatus         @default(EXTERNAL_PENDING)
  paymentReference String?
  notes            String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  participant      Participant           @relation(fields: [participantId], references: [id], onDelete: Cascade)
  primaryCheckout  RegistrationCheckout? @relation("PrimaryRegistration")
  checkout         RegistrationCheckout? @relation("RegistrationCheckoutBatch", fields: [checkoutId], references: [id], onDelete: SetNull)

  @@index([paymentStatus])
  @@index([paymentReference])
  @@index([checkoutId])
  @@index([createdAt])
}

model RegistrationCheckout {
  id                  String                     @id @default(cuid())
  idempotencyKey      String                     @unique
  email               String
  payload             Json
  paymentReference    String?                    @unique
  paymentOrderId      String?                    @unique
  paymentUrl          String?
  status              RegistrationCheckoutStatus @default(PENDING)
  registrationId      String?                    @unique
  confirmedAt         DateTime?
  paymentCompletedAt  DateTime?
  paymentReviewReason String?
  lastReconciledAt    DateTime?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  registration        Registration?              @relation("PrimaryRegistration", fields: [registrationId], references: [id], onDelete: SetNull)
  registrations       Registration[]             @relation("RegistrationCheckoutBatch")

  @@index([email])
  @@index([status, createdAt])
}

model Rsvp {
  id                 String        @id @default(cuid())
  participantId      String?
  source             RsvpSource    @default(FORM)
  firstName          String
  lastName           String
  email              String        @unique
  adultAttendeeCount Int?
  childAttendeeCount Int?
  attendeeCount      Int           @default(1)
  familyNames        String?
  dietaryNotes       String?
  notes              String?
  createdAt          DateTime      @default(now())
  participant        Participant?  @relation(fields: [participantId], references: [id], onDelete: SetNull)
  checkout           RsvpCheckout?

  @@unique([participantId, source], name: "participantId_source")
  @@index([createdAt])
}

model RsvpCheckout {
  id                  String             @id @default(cuid())
  idempotencyKey      String             @unique
  email               String
  payload             Json
  paymentReference    String?            @unique
  paymentOrderId      String?            @unique
  paymentUrl          String?
  status              RsvpCheckoutStatus @default(PENDING)
  rsvpId              String?            @unique
  confirmedAt         DateTime?
  paymentCompletedAt  DateTime?
  paymentReviewReason String?
  lastReconciledAt    DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  rsvp                Rsvp?              @relation(fields: [rsvpId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([status, createdAt])
}

model MarketplaceListing {
  id              String                      @id @default(cuid())
  slug            String                      @unique
  title           String
  description     String?
  imageUrl        String?
  fulfillmentNote String?
  status          MarketplaceListingStatus    @default(DRAFT)
  sortOrder       Int                         @default(0)
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt
  variants        MarketplaceListingVariant[]
  checkoutItems   MarketplaceCheckoutItem[]
  orderItems      MarketplaceOrderItem[]

  @@index([status, sortOrder])
}

model MarketplaceListingVariant {
  id                String                    @id @default(cuid())
  listingId         String
  label             String
  sku               String?                   @unique
  unitAmount        Int
  currency          String
  inventoryQuantity Int?
  isActive          Boolean                   @default(true)
  sortOrder         Int                       @default(0)
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  listing           MarketplaceListing        @relation(fields: [listingId], references: [id], onDelete: Cascade)
  checkoutItems     MarketplaceCheckoutItem[]
  orderItems        MarketplaceOrderItem[]

  @@unique([listingId, label])
  @@index([listingId, isActive, sortOrder])
}

model MarketplaceCheckout {
  id               String                      @id @default(cuid())
  idempotencyKey   String                      @unique
  publicTokenHash  String                      @unique
  snapshotHash     String
  buyerEmail       String?
  buyerName        String?
  status           MarketplaceCheckoutStatus   @default(PENDING)
  currency         String
  subtotalAmount   Int
  taxAmount        Int                         @default(0)
  shippingAmount   Int                         @default(0)
  discountAmount   Int                         @default(0)
  totalAmount      Int
  requestSnapshot  Json?
  customerSnapshot Json?
  expiresAt        DateTime
  confirmedAt      DateTime?
  canceledAt       DateTime?
  expiredAt        DateTime?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  items            MarketplaceCheckoutItem[]
  paymentAttempts  MarketplacePaymentAttempt[]
  order            MarketplaceOrder?

  @@index([buyerEmail, createdAt])
  @@index([status, createdAt])
  @@index([expiresAt])
}

model MarketplaceCheckoutItem {
  id             String                     @id @default(cuid())
  checkoutId     String
  listingId      String?
  variantId      String?
  lineNumber     Int
  title          String
  variantLabel   String?
  sku            String?
  quantity       Int
  currency       String
  unitAmount     Int
  totalAmount    Int
  detailSnapshot Json
  createdAt      DateTime                   @default(now())
  checkout       MarketplaceCheckout        @relation(fields: [checkoutId], references: [id], onDelete: Cascade)
  listing        MarketplaceListing?        @relation(fields: [listingId], references: [id], onDelete: SetNull)
  variant        MarketplaceListingVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([checkoutId, lineNumber])
  @@index([listingId])
  @@index([variantId])
}

model MarketplacePaymentAttempt {
  id                  String                          @id @default(cuid())
  checkoutId          String
  provider            MarketplacePaymentProvider      @default(SQUARE)
  status              MarketplacePaymentAttemptStatus @default(PENDING)
  idempotencyKey      String                          @unique
  expectedCurrency    String
  expectedTotalAmount Int
  providerLinkId      String?                         @unique
  providerOrderId     String?                         @unique
  providerPaymentId   String?                         @unique
  paymentUrl          String?
  expiresAt           DateTime?
  completedAt         DateTime?
  lastReconciledAt    DateTime?
  createdAt           DateTime                        @default(now())
  updatedAt           DateTime                        @updatedAt
  checkout            MarketplaceCheckout             @relation(fields: [checkoutId], references: [id], onDelete: Cascade)

  @@index([checkoutId, status, createdAt])
}

model MarketplaceOrder {
  id                String                       @id @default(cuid())
  checkoutId        String                       @unique
  publicTokenHash   String                       @unique
  buyerEmail        String?
  buyerName         String?
  currency          String
  subtotalAmount    Int
  taxAmount         Int                          @default(0)
  shippingAmount    Int                          @default(0)
  discountAmount    Int                          @default(0)
  totalAmount       Int
  customerSnapshot  Json?
  paymentProvider   MarketplacePaymentProvider
  providerOrderId   String?
  fulfillmentStatus MarketplaceFulfillmentStatus @default(UNFULFILLED)
  confirmedAt       DateTime
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt
  checkout          MarketplaceCheckout          @relation(fields: [checkoutId], references: [id], onDelete: Restrict)
  items             MarketplaceOrderItem[]

  @@index([buyerEmail, createdAt])
  @@index([fulfillmentStatus, createdAt])
}

model MarketplaceOrderItem {
  id             String                     @id @default(cuid())
  orderId        String
  listingId      String?
  variantId      String?
  lineNumber     Int
  title          String
  variantLabel   String?
  sku            String?
  quantity       Int
  currency       String
  unitAmount     Int
  totalAmount    Int
  detailSnapshot Json
  createdAt      DateTime                   @default(now())
  order          MarketplaceOrder           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  listing        MarketplaceListing?        @relation(fields: [listingId], references: [id], onDelete: SetNull)
  variant        MarketplaceListingVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([orderId, lineNumber])
  @@index([listingId])
  @@index([variantId])
}

model Feedback {
  id                String            @id @default(cuid())
  name              String?
  email             String?
  rating            Int?
  category          String
  message           String
  createdAt         DateTime          @default(now())
  remembrancePhotos PhotoSubmission[]

  @@index([category])
  @@index([createdAt])
}

model PhotoSubmission {
  id             String       @id @default(cuid())
  submitterName  String
  submitterEmail String
  caption        String?
  purpose        PhotoPurpose @default(GALLERY)
  feedbackId     String?
  s3Key          String       @unique
  approvedS3Key  String?
  status         PhotoStatus  @default(PENDING)
  reviewNotes    String?
  approvedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  feedback       Feedback?    @relation(fields: [feedbackId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([feedbackId])
}

model PairingGroup {
  id          String          @id @default(cuid())
  name        String
  teeTime     DateTime?
  sortOrder   Int
  status      PairingStatus   @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  members     PairingMember[]

  @@index([status, sortOrder])
}

model PairingMember {
  id             String       @id @default(cuid())
  groupId        String
  participantId  String
  slot           Int
  snapshotScore  Int
  snapshotAge    Int
  snapshotGender Gender
  group          PairingGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  participant    Participant  @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([groupId, slot])
  @@index([participantId])
}

model EventSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}
